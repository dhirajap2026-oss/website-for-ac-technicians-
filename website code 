<script>
  // Snowflakes
  const container = document.getElementById('snowflakes');
  for (let i = 0; i < 18; i++) {
    const s = document.createElement('span');
    s.className = 'snowflake';
    s.textContent = ['❄','❅','❆'][i % 3];
    s.style.left = Math.random() * 100 + 'vw';
    s.style.animationDuration = (6 + Math.random() * 10) + 's';
    s.style.animationDelay = (Math.random() * 8) + 's';
    s.style.fontSize = (0.7 + Math.random() * 1.2) + 'rem';
    container.appendChild(s);
  }

  // Set min date to today
  const today = new Date().toISOString().split('T')[0];
  document.getElementById('serviceDate').min = today;
  document.getElementById('serviceDate').value = today;

  // Select time slot
  let selectedSlot = '';
  function selectSlot(el) {
    if (el.classList.contains('unavailable')) return;
    document.querySelectorAll('.time-slot').forEach(t => t.classList.remove('selected'));
    el.classList.add('selected');
    selectedSlot = el.textContent.trim();
  }

  // Pre-select service from card buttons
  function selectService(name) {
    document.getElementById('serviceSelect').value = name;
    document.getElementById('booking').scrollIntoView({ behavior: 'smooth' });
  }

  // Submit booking
  function submitBooking() {
    const name   = document.getElementById('custName').value.trim();
    const phone  = document.getElementById('custPhone').value.trim();
    const svc    = document.getElementById('serviceSelect').value;
    const date   = document.getElementById('serviceDate').value;

    if (!name)  { alert('Please enter your name.'); return; }
    if (!phone || phone.length < 10) { alert('Please enter a valid 10-digit phone number.'); return; }
    if (!svc)   { alert('Please select a service.'); return; }
    if (!date)  { alert('Please select a preferred date.'); return; }
    if (!selectedSlot) { alert('Please select a preferred time slot.'); return; }

    const toast = document.getElementById('toast');
    toast.style.display = 'block';
    setTimeout(() => { toast.style.display = 'none'; }, 4000);

    // Reset form
    document.getElementById('custName').value = '';
    document.getElementById('custPhone').value = '';
    document.getElementById('custEmail').value = '';
    document.getElementById('custArea').value = '';
    document.getElementById('serviceSelect').value = '';
    document.getElementById('serviceDate').value = today;
    document.getElementById('issueDesc').value = '';
    document.querySelectorAll('.time-slot').forEach(t => t.classList.remove('selected'));
    selectedSlot = '';
  }
</script>
</body>
</html>
