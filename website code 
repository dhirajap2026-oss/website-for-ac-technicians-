<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>CoolFix AC Services</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet"/>
<style>
  :root {
    --ice: #e0f4ff;
    --sky: #0ea5e9;
    --deep: #0c1a2e;
    --navy: #0f2744;
    --frost: #cce9f8;
    --white: #ffffff;
    --gray: #94a3b8;
    --accent: #f97316;
    --card-bg: #132238;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    font-family: 'DM Sans', sans-serif;
    background: var(--deep);
    color: var(--white);
    overflow-x: hidden;
  }

  /* ── HERO ── */
  header {
    position: relative;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
    padding: 2rem;
    overflow: hidden;
  }

  header::before {
    content: '';
    position: absolute; inset: 0;
    background: radial-gradient(ellipse 80% 60% at 50% 30%, #1e4d7b 0%, #0c1a2e 70%);
    z-index: 0;
  }

  .snowflakes {
    position: absolute; inset: 0; pointer-events: none; z-index: 1;
  }
  .snowflake {
    position: absolute;
    color: #7dd3fc;
    font-size: 1.2rem;
    animation: fall linear infinite;
    opacity: 0.4;
  }
  @keyframes fall {
    0%   { transform: translateY(-40px) rotate(0deg); opacity: 0.4; }
    100% { transform: translateY(110vh) rotate(360deg); opacity: 0; }
  }

  .nav {
    position: fixed; top: 0; left: 0; right: 0;
    display: flex; justify-content: space-between; align-items: center;
    padding: 1.2rem 3rem;
    background: rgba(12,26,46,0.85);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(14,165,233,0.15);
    z-index: 100;
  }
  .nav-logo {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 1.8rem;
    color: var(--sky);
    letter-spacing: 2px;
  }
  .nav-links a {
    color: var(--frost);
    text-decoration: none;
    margin-left: 2rem;
    font-size: 0.9rem;
    font-weight: 500;
    transition: color 0.2s;
  }
  .nav-links a:hover { color: var(--sky); }

  .hero-content { position: relative; z-index: 2; max-width: 700px; }

  .badge {
    display: inline-block;
    background: rgba(14,165,233,0.15);
    border: 1px solid rgba(14,165,233,0.4);
    color: var(--sky);
    padding: 0.4rem 1rem;
    border-radius: 999px;
    font-size: 0.8rem;
    letter-spacing: 2px;
    text-transform: uppercase;
    margin-bottom: 1.5rem;
    animation: fadeUp 0.6s ease both;
  }

  .hero-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(3.5rem, 10vw, 7rem);
    line-height: 0.95;
    color: var(--white);
    animation: fadeUp 0.7s 0.1s ease both;
  }
  .hero-title span { color: var(--sky); }

  .hero-sub {
    margin-top: 1.2rem;
    color: var(--gray);
    font-size: 1.1rem;
    line-height: 1.7;
    animation: fadeUp 0.7s 0.2s ease both;
  }

  .hero-cta {
    margin-top: 2.5rem;
    display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;
    animation: fadeUp 0.7s 0.3s ease both;
  }

  .btn-primary {
    background: var(--sky);
    color: var(--deep);
    padding: 0.85rem 2.2rem;
    border-radius: 8px;
    font-weight: 600;
    font-size: 0.95rem;
    border: none;
    cursor: pointer;
    transition: transform 0.15s, box-shadow 0.15s;
    text-decoration: none;
  }
  .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(14,165,233,0.35); }

  .btn-outline {
    background: transparent;
    color: var(--frost);
    padding: 0.85rem 2.2rem;
    border-radius: 8px;
    font-weight: 500;
    font-size: 0.95rem;
    border: 1px solid rgba(255,255,255,0.2);
    cursor: pointer;
    transition: border-color 0.2s, color 0.2s;
    text-decoration: none;
  }
  .btn-outline:hover { border-color: var(--sky); color: var(--sky); }

  .stats {
    position: relative; z-index: 2;
    display: flex; gap: 3rem; margin-top: 4rem;
    animation: fadeUp 0.7s 0.4s ease both;
  }
  .stat-item { text-align: center; }
  .stat-num {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 2.4rem;
    color: var(--sky);
    line-height: 1;
  }
  .stat-label { font-size: 0.75rem; color: var(--gray); letter-spacing: 1px; margin-top: 0.2rem; }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(24px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* ── SECTIONS ── */
  section {
    padding: 6rem 2rem;
    max-width: 1200px;
    margin: 0 auto;
  }

  .section-label {
    color: var(--sky);
    font-size: 0.75rem;
    letter-spacing: 3px;
    text-transform: uppercase;
    margin-bottom: 0.6rem;
  }
  .section-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(2.2rem, 5vw, 3.5rem);
    line-height: 1;
    margin-bottom: 1rem;
  }
  .section-sub {
    color: var(--gray);
    max-width: 520px;
    line-height: 1.7;
  }

  /* ── SERVICES GRID ── */
  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.5rem;
    margin-top: 3rem;
  }

  .service-card {
    background: var(--card-bg);
    border: 1px solid rgba(14,165,233,0.1);
    border-radius: 16px;
    padding: 2rem;
    cursor: pointer;
    transition: transform 0.2s, border-color 0.2s, box-shadow 0.2s;
    position: relative;
    overflow: hidden;
  }
  .service-card::before {
    content: '';
    position: absolute; top: 0; left: 0; right: 0;
    height: 3px;
    background: linear-gradient(90deg, var(--sky), transparent);
    opacity: 0;
    transition: opacity 0.3s;
  }
  .service-card:hover { transform: translateY(-4px); border-color: rgba(14,165,233,0.4); box-shadow: 0 12px 40px rgba(14,165,233,0.12); }
  .service-card:hover::before { opacity: 1; }

  .service-icon {
    font-size: 2.2rem;
    margin-bottom: 1rem;
  }
  .service-name {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 1.5rem;
    color: var(--white);
    margin-bottom: 0.5rem;
    letter-spacing: 1px;
  }
  .service-desc {
    color: var(--gray);
    font-size: 0.9rem;
    line-height: 1.65;
    margin-bottom: 1.2rem;
  }
  .service-items {
    list-style: none;
    margin-bottom: 1.5rem;
  }
  .service-items li {
    display: flex; align-items: center; gap: 0.5rem;
    font-size: 0.82rem;
    color: var(--frost);
    padding: 0.25rem 0;
  }
  .service-items li::before {
    content: '✓';
    color: var(--sky);
    font-weight: 700;
    flex-shrink: 0;
  }
  .service-price {
    display: flex; justify-content: space-between; align-items: center;
  }
  .price-tag {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 1.6rem;
    color: var(--sky);
  }
  .price-tag span { font-size: 0.8rem; color: var(--gray); font-family: 'DM Sans', sans-serif; }
  .book-btn {
    background: rgba(14,165,233,0.1);
    color: var(--sky);
    border: 1px solid rgba(14,165,233,0.3);
    padding: 0.5rem 1.2rem;
    border-radius: 6px;
    font-size: 0.82rem;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.2s, color 0.2s;
  }
  .book-btn:hover { background: var(--sky); color: var(--deep); }

  /* ── BOOKING FORM ── */
  #booking {
    background: var(--navy);
    border-radius: 24px;
    padding: 4rem;
    margin: 0 auto;
    max-width: 900px;
    border: 1px solid rgba(14,165,233,0.15);
  }

  .form-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    margin-top: 2.5rem;
  }
  .form-group { display: flex; flex-direction: column; gap: 0.5rem; }
  .form-group.full { grid-column: 1 / -1; }
  label { font-size: 0.8rem; color: var(--sky); letter-spacing: 1px; text-transform: uppercase; }
  input, select, textarea {
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 8px;
    padding: 0.8rem 1rem;
    color: var(--white);
    font-family: 'DM Sans', sans-serif;
    font-size: 0.95rem;
    transition: border-color 0.2s;
    outline: none;
  }
  input:focus, select:focus, textarea:focus {
    border-color: var(--sky);
    background: rgba(14,165,233,0.05);
  }
  select option { background: var(--deep); }
  textarea { resize: vertical; min-height: 90px; }

  /* Time Slots */
  .time-slots {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(130px, 1fr));
    gap: 0.75rem;
    margin-top: 0.5rem;
  }
  .time-slot {
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 8px;
    padding: 0.75rem 0.5rem;
    text-align: center;
    cursor: pointer;
    transition: all 0.2s;
    font-size: 0.85rem;
    color: var(--frost);
    user-select: none;
  }
  .time-slot:hover { border-color: var(--sky); color: var(--sky); }
  .time-slot.selected {
    background: var(--sky);
    border-color: var(--sky);
    color: var(--deep);
    font-weight: 600;
  }
  .time-slot.unavailable {
    opacity: 0.3;
    cursor: not-allowed;
    text-decoration: line-through;
  }

  .submit-btn {
    width: 100%;
    background: var(--sky);
    color: var(--deep);
    border: none;
    border-radius: 10px;
    padding: 1rem;
    font-size: 1rem;
    font-weight: 700;
    cursor: pointer;
    margin-top: 1.5rem;
    transition: opacity 0.2s, transform 0.15s;
    letter-spacing: 0.5px;
  }
  .submit-btn:hover { opacity: 0.9; transform: translateY(-1px); }

  /* Success toast */
  .toast {
    display: none;
    position: fixed;
    bottom: 2rem; right: 2rem;
    background: #10b981;
    color: white;
    padding: 1rem 1.5rem;
    border-radius: 10px;
    font-weight: 600;
    z-index: 999;
    animation: slideIn 0.3s ease;
  }
  @keyframes slideIn {
    from { transform: translateX(60px); opacity: 0; }
    to   { transform: translateX(0);    opacity: 1; }
  }

  /* ── WHY US ── */
  .features-row {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 1.5rem;
    margin-top: 3rem;
  }
  .feature-card {
    background: var(--card-bg);
    border-radius: 12px;
    padding: 1.8rem;
    border: 1px solid rgba(14,165,233,0.08);
    transition: border-color 0.2s;
  }
  .feature-card:hover { border-color: rgba(14,165,233,0.3); }
  .feature-icon { font-size: 1.8rem; margin-bottom: 0.8rem; }
  .feature-title { font-weight: 600; margin-bottom: 0.4rem; }
  .feature-desc { font-size: 0.85rem; color: var(--gray); line-height: 1.6; }

  /* ── FOOTER ── */
  footer {
    text-align: center;
    padding: 2rem;
    color: var(--gray);
    font-size: 0.85rem;
    border-top: 1px solid rgba(255,255,255,0.06);
  }

  /* ── RESPONSIVE ── */
  @media (max-width: 700px) {
    .nav-links { display: none; }
    .form-grid { grid-template-columns: 1fr; }
    #booking { padding: 2rem 1.5rem; }
    .stats { gap: 1.5rem; }
  }
</style>
</head>
